Given a binary tree, your task is to count the number of leaf nodes present in the tree.

A leaf node is a node that does not have any left or right child.
ANSWER
import java.io.*;
import java.util.*;

public class Solution {
    static void leaf(Node root)
    {
        int c=0;
       Queue <Node> q=new LinkedList<>(); 
       q.offer(root);
       while(!q.isEmpty())
       {
        
        Node t=q.poll();
        if(t.left==null  && t.right==null) c++;
        if(t.left!=null) q.offer(t.left);
        if(t.right!=null) q.offer(t.right);
        
       }
       System.out.print(c);
       
        
       
        
        
    }

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Solution. */
        Queue <Node> q=new LinkedList<>();
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int []a=new int[n];
        for(int i=0;i<n;i++) a[i]=sc.nextInt();
        Node root=new Node(a[0]);
        q.offer(root);
        for(int i=1;i<n;i++)
        {
            Node t=q.poll();
            if(a[i]!=-1)
            {
                Node l=new Node(a[i]);
                t.left=l;
                q.offer(l);
            }
            if(++i<n && a[i]!=-1)
            {
                Node r=new Node(a[i]);
                t.right=r;
                q.offer(r);
            }
        }
        leaf(root);
    }
}
class Node
{
    int data;
    Node left,right;
    Node (int val)
    {
        data=val;
        left=right=null;
        
    }
}
