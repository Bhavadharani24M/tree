Print the zigzag level order traversal of the binary tree.

Each level should be printed on a new line.

Values in a level should be space-separated.
ANSWER
import java.io.*;
import java.util.*;
class Node
{
    int data;
    Node left,right;
    Node(int val)
    {
        data=val;
        left=right=null;
    }
}

public class Solution {
     static void zigzag(Node root)
        {
         boolean d=true;
      Queue <Node> qu=new LinkedList<>();
      qu.offer(root);
      while(!qu.isEmpty())
      {
        int n=qu.size();
        ArrayList <Integer> l=new ArrayList<>();
        for(int i=0;i<n;i++)
        {
            Node t=qu.poll();
            if(d) l.add(t.data);
            else l.add(0,t.data);
            if(t.left!=null) qu.offer(t.left);
            if(t.right!=null) qu.offer(t.right);
            
        }
        for(int x:l)
        {
            System.out.print(x+" ");
        }
        System.out.println();
        d=!d;
      }
        }
    
   

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Solution. */
        Scanner sc=new Scanner(System.in);
        String []s=sc.nextLine().split(" ");
        Queue <Node> q=new LinkedList<>();
        Node root=new Node(Integer.valueOf(s[0]));
        q.offer(root);
        for(int i=1;i<s.length;i++)
        {
            Node t=q.poll();
            if(!s[i].equals("-1"))
            {
                Node l=new Node(Integer.valueOf(s[i]));
                t.left=l;
                q.offer(l);
                
            }
            if(++i<s.length && !s[i].equals("-1"))
            {
                Node r=new Node(Integer.valueOf(s[i]));
                t.right=r;
                q.offer(r);
            }
        }zigzag(root);
       
      
    }}

