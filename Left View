Given a binary tree, print the Left View of the tree. The left view contains the nodes that are visible when the tree is viewed from the left side. The first node at each level of the tree forms the left view.

The tree is provided using level-order insertion, where -1 represents a null node.
ANSWER
import java.io.*;
import java.util.*;
class Node
{
    int data;
    Node left,right;
    Node(int val)
    {
        data=val;
        left=right=null;
    }
}

public class Solution {
    static void left(Node root)
    {
        Queue <Node> qu=new LinkedList<>();
        qu.offer(root);
        while(!qu.isEmpty())
        {
            int n=qu.size();
            for(int i=0;i<n;i++)
            {
                Node t=qu.poll();
                if(i==0) System.out.print(t.data+" ");
                if(t.left!=null) qu.offer(t.left);
                if(t.right!=null) qu.offer(t.right);
            }
        }
    }
    

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Solution. */
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int a[]=new int[n];
        for(int i=0;i<n;i++)
        {
            a[i]=sc.nextInt();
        }
        Queue <Node> q=new LinkedList<>();
        Node root =new Node(a[0]);
        q.offer(root);
        for(int i=1;i<n;i++)
        {
            Node t=q.poll();
            if(a[i]!=-1)
            {
                Node l=new Node(a[i]);
                t.left=l;
                q.offer(l);
            }
            if(++i<n && a[i]!=-1)
            {
                Node r=new Node(a[i]);
                t.right=r;
                q.offer(r);
            }
        }
        left(root);
        
    }
}
