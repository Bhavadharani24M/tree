Given a binary tree, your task is to count the total number of nodes present in the tree.

A node is counted if it contains a valid value. Null nodes are not counted.
ANSWER
import java.io.*;
import java.util.*;
class Node
{
    int data;
    Node left,right;
    Node(int val)
    {
        data=val;
        left=right=null;
    }
}

public class Solution {
    

    public static void main(String[] args) {
        /* Enter your code here. Read input from STDIN. Print output to STDOUT. Your class should be named Solution. */
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int a[]=new int[n];
        for(int i=0;i<n;i++)
        {
            a[i]=sc.nextInt();
        }
        Queue <Node> q=new LinkedList<>();
        Node root =new Node(a[0]);
        q.offer(root);int c=1;
        for(int i=1;i<n;i++)
        {
            Node t=q.poll();
            if(a[i]!=-1)
            {
                Node l=new Node(a[i]);
                t.left=l;
                q.offer(l);c++;
            }
            if(++i<n && a[i]!=-1)
            {
                Node r=new Node(a[i]);
                t.right=r;
                q.offer(r);c++;
            }
        }
        System.out.print(c);
       
    }
}
